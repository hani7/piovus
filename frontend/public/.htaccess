Options -MultiViews
RewriteEngine On

# Ne PAS réécrire les appels API et admin Django
RewriteCond %{REQUEST_URI} ^/api/ [OR]
RewriteCond %{REQUEST_URI} ^/piove-secure-gate-2026/
RewriteRule ^ - [L]

# React SPA — renvoie tout vers index.html (sauf fichiers existants)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# Cache des assets statiques
<FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|ico|webp)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
</FilesMatch>

# Pas de cache pour index.html
<FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
